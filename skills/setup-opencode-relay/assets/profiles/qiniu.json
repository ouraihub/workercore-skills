{
  "name": "qiniu",
  "displayName": "Qiniu (七牛云)",
  "baseUrl": "https://api.qnaigc.com",
  "key": { "mode": "env", "ref": "QINIU_API_KEY" },
  "apis": {
    "openai": { "enabled": true, "pathV1": true },
    "anthropic": { "enabled": true, "pathV1": false }
  },
  "models": {
    "opus": { "id": "claude-4.6-sonnet", "name": "Claude 4.6 Sonnet", "via": "anthropic", "ctx": 200000, "out": 64000 },
    "gptHigh": { "id": "gpt-5.4", "name": "GPT-5.4", "via": "openai", "ctx": 400000, "out": 128000 },
    "gptCheap": { "id": "gpt-5.4-mini", "name": "GPT-5.4 Mini", "via": "openai", "ctx": 400000, "out": 128000 }
  },
  "quirks": {
    "userAgentWafBlock": false,
    "userAgentValue": "pi/0.80.3"
  },
  "notes": "海外模型不在 /v1/models 列表里但可调用；gpt 系要求 max_tokens>=16；opencode 侧全部走 openai 兼容端点（claude-4.6-sonnet 在 /v1/chat/completions 也 200），anthropic.pathV1 仅供 pi 参考",
  "verified": "2026-07-10 · opencode 1.17.18 端到端通过（qiniu/gpt-5.4 + qiniu/claude-4.6-sonnet）"
}
