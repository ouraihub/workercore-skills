{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/dev/assets/oh-my-opencode.schema.json",
  // 模型映射：全部走自定义中转 provider "__PROFILE_NAME__"（模型见 profile：opus / gptCheap / gptHigh）。
  // 依据官方 agent-model-matching.md / overview.md：
  //  - sisyphus 主编排器：优先级 1 = Claude Opus 4.7/4.8，有 Claude 家族专用 prompt → opus。
  //  - hephaestus 只吃 GPT 家族（单一 prompt，跨家族退化）→ gptHigh。
  //  - variant 只对 gpt 系列有效；opus 未定义 variants，opus 角色不写 variant。
  //  - 工具类 agent（explore/librarian）用便宜快速档 gptCheap。
  "agents": {
    "sisyphus": { "model": "__PROFILE_NAME__/__OPUS_ID__" },
    "hephaestus": { "model": "__PROFILE_NAME__/__GPTHIGH_ID__", "variant": "medium" },
    "oracle": { "model": "__PROFILE_NAME__/__GPTHIGH_ID__", "variant": "high" },
    "prometheus": { "model": "__PROFILE_NAME__/__OPUS_ID__" },
    "atlas": { "model": "__PROFILE_NAME__/__GPTCHEAP_ID__" },
    "metis": { "model": "__PROFILE_NAME__/__OPUS_ID__" },
    "momus": { "model": "__PROFILE_NAME__/__GPTCHEAP_ID__", "variant": "xhigh" },
    "sisyphus-junior": { "model": "__PROFILE_NAME__/__GPTHIGH_ID__", "variant": "medium" },
    "librarian": { "model": "__PROFILE_NAME__/__GPTCHEAP_ID__", "variant": "low" },
    "explore": { "model": "__PROFILE_NAME__/__GPTCHEAP_ID__", "variant": "low" },
    "multimodal-looker": { "model": "__PROFILE_NAME__/__GPTCHEAP_ID__" }
  },
  "categories": {
    "visual-engineering": { "model": "__PROFILE_NAME__/__GPTHIGH_ID__", "variant": "high" },
    "ultrabrain": { "model": "__PROFILE_NAME__/__OPUS_ID__" },
    "deep": { "model": "__PROFILE_NAME__/__GPTHIGH_ID__", "variant": "xhigh" },
    "artistry": { "model": "__PROFILE_NAME__/__OPUS_ID__" },
    "quick": { "model": "__PROFILE_NAME__/__GPTCHEAP_ID__", "variant": "low" },
    "unspecified-low": { "model": "__PROFILE_NAME__/__GPTCHEAP_ID__", "variant": "medium" },
    "unspecified-high": { "model": "__PROFILE_NAME__/__OPUS_ID__" },
    "writing": { "model": "__PROFILE_NAME__/__OPUS_ID__" }
  },
  "background_task": {
    "modelConcurrency": {
      "__PROFILE_NAME__/__OPUS_ID__": 2,
      "__PROFILE_NAME__/__GPTCHEAP_ID__": 2,
      "__PROFILE_NAME__/__GPTHIGH_ID__": 2
    },
    "providerConcurrency": { "__PROFILE_NAME__": 3 }
  }
}
