{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["oh-my-openagent@latest"],
  "provider": {
    "__PROFILE_NAME__": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "__PROFILE_DISPLAY__",
      "options": {
        "apiKey": "{env:__PROFILE_KEY_REF__}",
        "baseURL": "__PROFILE_BASEURL_V1__"
      },
      "models": {
        "__OPUS_ID__": {
          "name": "__OPUS_NAME__",
          "limit": { "context": 200000, "output": 64000 }
        },
        "__GPTCHEAP_ID__": {
          "name": "__GPTCHEAP_NAME__",
          "limit": { "context": 1050000, "output": 128000 },
          "variants": { "high": {}, "low": {}, "medium": {}, "xhigh": {} }
        },
        "__GPTHIGH_ID__": {
          "name": "__GPTHIGH_NAME__",
          "limit": { "context": 400000, "output": 128000 },
          "variants": { "high": {}, "low": {}, "medium": {}, "xhigh": {} }
        },
        "__GPT56_ID__": {
          "name": "__GPT56_NAME__",
          "limit": { "context": 400000, "output": 128000 },
          "variants": { "high": {}, "low": {}, "medium": {}, "xhigh": {} }
        }
      }
    }
  }
}
