{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/dev/assets/oh-my-opencode.schema.json",
  // 模型映射：全部走自定义中转 provider "easyclaude"（模型：claude-opus-4-8 / gpt-5.4 / gpt-5.5）。
  // 依据官方 agent-model-matching.md / overview.md：
  //  - sisyphus 主编排器：优先级 1 = Claude Opus 4.7/4.8，有 Claude 家族专用 prompt。
  //  - hephaestus 只吃 GPT 家族（单一 prompt，跨家族退化）。
  //  - variant 只对 gpt-5.4/gpt-5.5 有效；opus 未定义 variants，opus 角色不写 variant。
  //  - 工具类 agent（explore/librarian）用便宜快速档。
  "agents": {
    "sisyphus": { "model": "easyclaude/claude-opus-4-8" },
    "hephaestus": { "model": "easyclaude/gpt-5.5", "variant": "medium" },
    "oracle": { "model": "easyclaude/gpt-5.5", "variant": "high" },
    "prometheus": { "model": "easyclaude/claude-opus-4-8" },
    "atlas": { "model": "easyclaude/gpt-5.4" },
    "metis": { "model": "easyclaude/claude-opus-4-8" },
    "momus": { "model": "easyclaude/gpt-5.4", "variant": "xhigh" },
    "sisyphus-junior": { "model": "easyclaude/gpt-5.5", "variant": "medium" },
    "librarian": { "model": "easyclaude/gpt-5.4", "variant": "low" },
    "explore": { "model": "easyclaude/gpt-5.4", "variant": "low" },
    "multimodal-looker": { "model": "easyclaude/gpt-5.4" }
  },
  "categories": {
    "visual-engineering": { "model": "easyclaude/gpt-5.5", "variant": "high" },
    "ultrabrain": { "model": "easyclaude/claude-opus-4-8" },
    "deep": { "model": "easyclaude/gpt-5.5", "variant": "xhigh" },
    "artistry": { "model": "easyclaude/claude-opus-4-8" },
    "quick": { "model": "easyclaude/gpt-5.4", "variant": "low" },
    "unspecified-low": { "model": "easyclaude/gpt-5.4", "variant": "medium" },
    "unspecified-high": { "model": "easyclaude/claude-opus-4-8" },
    "writing": { "model": "easyclaude/claude-opus-4-8" }
  },
  "background_task": {
    "modelConcurrency": {
      "easyclaude/claude-opus-4-8": 2,
      "easyclaude/gpt-5.4": 2,
      "easyclaude/gpt-5.5": 2
    },
    "providerConcurrency": { "easyclaude": 3 }
  }
}
